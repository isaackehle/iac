# In Portainer: set these under the stack's Environment variables section,
# not as a real .env file, matching how the other stacks here are deployed.

# Tailscale auth key for the sidecar node
# Generate at https://login.tailscale.com/admin/settings/keys
# Use a reusable, pre-authorized key
TS_AUTHKEY_PIHOLE=

TS_CERT_DOMAIN=pihole.<tailnet>.ts.net