# Copy to .env and fill in values before running docker compose up

# Plex claim token — get from https://www.plex.tv/claim
# Only required on first run to bind server to your Plex account
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# Tailscale auth key for the sidecar node
# Generate at https://login.tailscale.com/admin/settings/keys
# Use a reusable, pre-authorized key
TS_AUTHKEY_PLEX=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tailscale auth key for the sidecar node
# Generate at https://login.tailscale.com/admin/settings/keys
# Use a reusable, pre-authorized key
TS_AUTHKEY_PLEX=

TS_CERT_DOMAIN=plex.<tailnet>.ts.net